generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model batch {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(50)
  is_active  Boolean   @default(false)
  start_year Int
  end_year   Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  student    student[]
}

model department {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  code       String    @unique @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  student    student[]
  staff      staff[]
}

model project_group {
  id                                     Int                    @id @default(autoincrement())
  name                                   String                 @db.VarChar(150)
  title                                  String                 @db.VarChar(200)
  area                                   String?                @db.VarChar(100)
  description                            String?
  average_cpi                            Float?
  project_type_id                        Int?
  guide_id                               Int?
  convener_id                            Int?
  expert_id                              Int?
  created_at                             DateTime?              @default(now()) @db.Timestamp(6)
  updated_at                             DateTime?              @default(now()) @db.Timestamp(6)
  staff_project_group_convener_idTostaff staff?                 @relation("project_group_convener_idTostaff", fields: [convener_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff_project_group_expert_idTostaff   staff?                 @relation("project_group_expert_idTostaff", fields: [expert_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff_project_group_guide_idTostaff    staff?                 @relation("project_group_guide_idTostaff", fields: [guide_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_type                           project_type?          @relation(fields: [project_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_group_member                   project_group_member[]
  project_meeting                        project_meeting[]
  project_submission                     project_submission[]
}

model project_group_member {
  id            Int            @id @default(autoincrement())
  group_id      Int?
  student_id    Int?
  is_leader     Boolean?       @default(false)
  cgpa          Float?
  created_at    DateTime?      @default(now()) @db.Timestamp(6)
  updated_at    DateTime?      @default(now()) @db.Timestamp(6)
  project_group project_group? @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student       student?       @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([group_id, student_id])
}

model project_meeting {
  id                         Int                          @id @default(autoincrement())
  group_id                   Int?
  guide_id                   Int?
  meeting_datetime           DateTime                     @db.Timestamp(6)
  duration                   Int?                         // Duration in minutes
  purpose                    String?                      @db.VarChar(255)
  location                   String?                      @db.VarChar(100)
  meeting_link               String?                      @db.VarChar(500)
  agenda                     String?
  notes                      String?
  status                     meeting_status?              @default(SCHEDULED)
  status_note                String?
  created_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  project_group              project_group?               @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff                      staff?                       @relation(fields: [guide_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_meeting_attendance project_meeting_attendance[]
}

model project_meeting_attendance {
  id              Int              @id @default(autoincrement())
  meeting_id      Int?
  student_id      Int?
  is_present      Boolean?         @default(false)
  remarks         String?          @db.VarChar(100)
  created_at      DateTime?        @default(now()) @db.Timestamp(6)
  updated_at      DateTime?        @default(now()) @db.Timestamp(6)
  project_meeting project_meeting? @relation(fields: [meeting_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student         student?         @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([meeting_id, student_id])
}

model project_type {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(100)
  description   String?
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  project_group project_group[]
}

model staff {
  id                                             Int               @id @default(autoincrement())
  name                                           String            @db.VarChar(150)
  phone                                          String?           @db.VarChar(20)
  email                                          String            @unique @db.VarChar(150)
  password                                       String
  role                                           user_role?        @default(FACULTY)
  description                                    String?
  created_at                                     DateTime?         @default(now()) @db.Timestamp(6)
  updated_at                                     DateTime?         @default(now()) @db.Timestamp(6)
  is_verified                                    Boolean?          @default(false)
  department_id                                  Int?
  department                                     department?       @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_group_project_group_convener_idTostaff project_group[]   @relation("project_group_convener_idTostaff")
  project_group_project_group_expert_idTostaff   project_group[]   @relation("project_group_expert_idTostaff")
  project_group_project_group_guide_idTostaff    project_group[]   @relation("project_group_guide_idTostaff")
  project_meeting                                project_meeting[]
}

model student {
  id                         Int                          @id @default(autoincrement())
  enrollment_no              String?                      @unique @db.VarChar(50)
  name                       String                       @db.VarChar(150)
  phone                      String?                      @db.VarChar(20)
  email                      String                       @unique @db.VarChar(150)
  description                String?
  created_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  updated_at                 DateTime?                    @default(now()) @db.Timestamp(6)
  password                   String?
  batch_id                   Int?
  department_id              Int?
  project_group_member       project_group_member[]
  project_meeting_attendance project_meeting_attendance[]
  batch                      batch?                       @relation(fields: [batch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department                 department?                  @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project_submission         project_submission[]
  cgpa                       Float?
}

model notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user_role  user_role
  type       String   @db.VarChar(50)
  title      String   @db.VarChar(200)
  message    String
  link       String?  @db.VarChar(255)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  
  @@index([user_id, user_role])
  @@index([is_read])
  @@index([created_at])
}

enum meeting_status {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum user_role {
  ADMIN
  FACULTY
  STUDENT
}

model project_submission {
  id              Int            @id @default(autoincrement())
  group_id        Int
  student_id      Int
  title           String         @db.VarChar(200)
  description     String?
  link            String         @db.VarChar(500)
  submission_type String         @default("LINK") @db.VarChar(50)
  created_at      DateTime       @default(now()) @db.Timestamp(6)
  project_group   project_group  @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student         student        @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([group_id])
  @@index([student_id])
}
